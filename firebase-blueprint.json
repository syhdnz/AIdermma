{
  "entities": {
    "User": {
      "title": "User",
      "description": "Firebase authenticated user profiles",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string" },
        "lastLoginAt": { "type": "string" }
      },
      "required": ["email", "createdAt", "lastLoginAt"]
    },
    "Scan": {
      "title": "Scan",
      "description": "A single Derma-AI skin scan and its analysis results",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "condition": { "type": "string" },
        "urgency": { "type": "string" },
        "confidence": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "imageUrl", "condition", "urgency", "confidence", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profile data."
    },
    "/users/{userId}/scans/{scanId}": {
      "schema": { "$ref": "#/entities/Scan" },
      "description": "Collection of scans belonging to a user."
    }
  }
}
